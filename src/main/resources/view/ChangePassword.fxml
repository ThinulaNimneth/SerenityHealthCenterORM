<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: #ECF0F1;"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="lk.ijse.serenityhealthcenter.controller.ChangePasswordController">

    <VBox alignment="CENTER" layoutX="100.0" layoutY="50.0" prefHeight="300.0" prefWidth="300.0"
          spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 30;">

        <Label text="Change Password" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

        <VBox spacing="10.0">
            <Label text="Current Password:"/>
            <PasswordField fx:id="txtCurrentPassword" promptText="Enter current password"/>
        </VBox>

        <VBox spacing="10.0">
            <Label text="New Password:"/>
            <PasswordField fx:id="txtNewPassword" promptText="Enter new password"/>
            <Label fx:id="lblPasswordStrength" text="Min 8 chars, letters and numbers required"
                   style="-fx-font-size: 10; -fx-text-fill: gray;"/>
        </VBox>

        <VBox spacing="10.0">
            <Label text="Confirm Password:"/>
            <PasswordField fx:id="txtConfirmPassword" promptText="Re-enter new password"/>
        </VBox>

        <CheckBox fx:id="chkShowPasswords" text="Show Passwords"/>

        <HBox spacing="15.0" alignment="CENTER">
            <Button fx:id="btnChangePassword" text="Change Password" onAction="#handleChangePassword"
                    style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-min-width: 120;"/>
            <Button fx:id="btnCancel" text="Cancel" onAction="#handleCancel"
                    style="-fx-min-width: 100;"/>
        </HBox>

        <Label fx:id="lblMessage" textFill="red"/>
    </VBox>
</AnchorPane>